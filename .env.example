# BudgetMate environment template
#
# Copy this file to .env and fill in values from your Firebase project.
# Never commit real secrets or production credentials.
#
# Expo note:
# Variables prefixed with EXPO_PUBLIC_ are available to the app at runtime.

# App
EXPO_PUBLIC_APP_ENV=development
EXPO_PUBLIC_APP_NAME=BudgetMate

# Firebase Web/App SDK config
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Optional: Firebase Emulator Suite (local development)
EXPO_PUBLIC_USE_FIREBASE_EMULATORS=false
EXPO_PUBLIC_FIRESTORE_EMULATOR_HOST=localhost
EXPO_PUBLIC_FIRESTORE_EMULATOR_PORT=8080
EXPO_PUBLIC_AUTH_EMULATOR_HOST=localhost
EXPO_PUBLIC_AUTH_EMULATOR_PORT=9099
