{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "prebuildCommand": "expo prebuild --clean"
    },
    "preview": {
      "distribution": "internal",
      "prebuildCommand": "expo prebuild --clean"
    },
    "production": {
      "autoIncrement": true,
      "prebuildCommand": "expo prebuild --clean",
      "environment": "production",
      "ios": {
        "image": "latest"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
